# --- Runtime mode ---
# Allowed values: development | staging | production | test
NODE_ENV=development

# HTTP server port
PORT=3000

# --- Persistence ---
# Allowed values: memory | postgres
EDUCLINK_PERSISTENCE=memory
# Required when EDUCLINK_PERSISTENCE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/educlink

# --- URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# --- Multi-tenant defaults ---
DEFAULT_TENANT_SLUG=demo-school

# --- Logging / observability ---
# LOG_FORMAT: pretty | json
LOG_LEVEL=info
LOG_FORMAT=pretty

# --- Security ---
# 32+ char random string used to sign session cookies and verify their integrity.
# REQUIRED in staging and production. In development, a built-in fallback is used
# if missing (with a startup warning) — do NOT rely on that fallback in real deployments.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

