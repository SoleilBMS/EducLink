# ============================================================
# EducLink — Production environment reference
# ============================================================
# Copy this file as the source of truth when configuring Railway,
# OVH ou tout autre hébergeur. Aucune valeur ici n'est secrète :
# remplace toutes les valeurs `change-me-*` avant déploiement.
# ============================================================

# --- Runtime mode ---
# Doit être "production" en prod. "staging" sur la préprod.
NODE_ENV=production

# --- HTTP server binding ---
# Railway injecte PORT automatiquement (ne pas le forcer).
# En self-host (OVH), PORT par défaut = 3000.
PORT=3000
# HOST par défaut = 0.0.0.0 en production (écoute toutes interfaces).
# Ne change cette valeur que si tu mets un reverse proxy localhost-only.
HOST=0.0.0.0

# --- Persistence (REQUIS en production) ---
# Allowed values: memory | postgres
# memory = sessions/données en RAM (test uniquement). POSTGRES OBLIGATOIRE en prod.
EDUCLINK_PERSISTENCE=postgres

# URL de connexion PostgreSQL.
# Railway : utiliser le binding `${{Postgres.DATABASE_URL}}` (variable de service).
# OVH/VPS : format postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://educlink:change-me-strong-password@db-host:5432/educlink

# --- URLs publiques ---
# URL publique de l'application (utilisée pour les liens absolus, les emails…)
NEXT_PUBLIC_APP_URL=https://app.educlink.example
API_URL=https://app.educlink.example

# Slug du tenant par défaut (utilisé par les routes legacy / la démo)
DEFAULT_TENANT_SLUG=demo-school

# --- Logging / observability ---
# json en production (structuré pour ingestion par Sentry, Datadog, etc.)
LOG_FORMAT=json
# debug | info | warn | error
LOG_LEVEL=info

# --- Security (CRITIQUE) ---
# Signe les cookies de session HMAC-SHA256.
# REQUIS en production, longueur minimale 32 caractères.
# Génère avec : openssl rand -hex 32
# NE JAMAIS commiter, NE JAMAIS réutiliser entre environnements.
SESSION_SECRET=change-me-with-openssl-rand-hex-32

# ============================================================
# Variables OPTIONNELLES (commentées par défaut)
# ============================================================

# --- AI provider (Sprint AI futur) ---
# Provider par défaut = dev-echo (stub, aucun appel externe).
# Pour activer un vrai provider (ex. Anthropic), décommenter :
# AI_DEFAULT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- Email transactional (OPS-04, requis pour USR-05 reset password) ---
# Provider recommandé : Resend (gratuit jusqu'à 3000 emails/mois)
# RESEND_API_KEY=re_...
# Adresse expéditeur vérifiée chez le provider
# MAIL_FROM_ADDRESS=noreply@educlink.example
# MAIL_FROM_NAME=EducLink

# --- Migration auto au démarrage ---
# Si 1, npm run start:railway exécute db:migrate avant de lancer le serveur.
# Recommandé en pilot (idempotent grâce à la table schema_migrations).
# Mettre à 0 si tu préfères piloter les migrations manuellement (release command Railway).
EDUCLINK_AUTO_MIGRATE=1

# --- Monitoring (OPS-06, futur) ---
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
